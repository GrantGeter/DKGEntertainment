# ─── Admin Auth ──────────────────────────────────────────────────────────────
# Change ADMIN_PASSWORD to something strong before deploying
ADMIN_PASSWORD=change-me
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_JWT_SECRET=generate-a-64-char-hex-string-here

# ─── Resend (Email) ───────────────────────────────────────────────────────────
# Sign up free at https://resend.com → Settings → API Keys
RESEND_API_KEY=re_your_key_here

# The "From" address — must be a verified domain in Resend
# Until your domain is verified, use: onboarding@resend.dev (Resend sandbox)
DKG_FROM_EMAIL=DKG Entertainment <onboarding@resend.dev>

# Where contact/booking notifications are delivered
DKG_TEAM_EMAIL=info@dkgentertainment.com

# ─── Site ─────────────────────────────────────────────────────────────────────
# Set to your production URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://your-project.pages.dev
